# ================================================================
#  BTC TRADING SYSTEM v13.1 (V14 audit fixes) — YOUR SETTINGS
#  ----------------------------------------------------------------
#  STEP 1: Replace every YOUR_... value with your real values
#  STEP 2: Save this file
#  STEP 3: Upload to private GitHub → connect to Railway
#  That's it — system starts trading automatically
#  NOTE: values here are OVERRIDDEN by anything already set as a
#  Railway environment variable (e.g. BINANCE_API_KEY). Only keys
#  that are NOT set in Railway actually come from this file.
# ================================================================
# ── BINANCE API (mandatory) ──────────────────────────────────────
BINANCE_API_KEY=YOUR_BINANCE_API_KEY_HERE
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET_HERE
# ── TESTNET (safe testing — no real money) ───────────────────────
USE_TESTNET=false
# ── YOUR CAPITAL ─────────────────────────────────────────────────
INITIAL_CAPITAL_USDT=77.93
# ── DASHBOARD PASSWORD ───────────────────────────────────────────
DASHBOARD_PASSWORD=MyPassword123
# ── TELEGRAM ALERTS (optional but strongly recommended) ──────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE
# ── NEWS API (optional) ──────────────────────────────────────────
NEWS_API_KEY=YOUR_NEWS_API_KEY_HERE
# ── RISK SETTINGS ────────────────────────────────────────────────
RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=5.0
CAUTION_LOSS_PCT=3.0
WEEKLY_LOSS_LIMIT_PCT=15.0
# V14 FIX: was 68.0 — your spec's base confidence is 62%, with the
# graduated escalation (2 losses +5%, 3 +10%, 4 +15%, 5 +20%) built
# on top of this base in code. Leaving this at 68 silently shifted
# every tier up (73/78/83/88% instead of 67/72/77/82%).
MIN_WIN_PROBABILITY=62.0
MAX_LEVERAGE=20
MAX_SPREAD_PCT=0.10
# V14 FIX: was 5 — your spec is 6 consecutive losses before shifting
# to paper mode (the graduated threshold above already handles 2-5).
MAX_CONSECUTIVE_LOSSES=6
PAPER_RECOVERY_HOURS=1.0
# V14 FIX: was 2 — your spec is 1 profitable paper trade (after fees
# & tax) before automatically resuming live trading.
PAPER_MIN_TRADES=1
MAX_TRADE_AGE_HOURS=24.0
# ── V8: FAST SCAN ────────────────────────────────────────────────
# Scans every 15s when no open trade (was 60s) — catches breakouts fast
SCAN_FAST_SECONDS=15
SCAN_SLOW_SECONDS=60
# ── V8: LOSS COOLDOWN ────────────────────────────────────────────
# Waits 15 min after any loss before entering next trade
LOSS_COOLDOWN_MINUTES=15
# ── V8: MULTI-TAKE-PROFIT ────────────────────────────────────────
TP1_ATR_RATIO=1.5
TP2_ATR_RATIO=2.5
TP3_ATR_RATIO=4.0
# V14 FIX: this was the original bug we chased all conversation —
# was 40.0/35.0 (leftover from the old v8.0 multi-TP structure).
# Current design: TP1 locks 15%, TP2 is a reference price only (0%
# closed there), and the remaining 85% rides an adaptive ATR trail
# to TP3 to let winners run.
TP1_CLOSE_PCT=15.0
TP2_CLOSE_PCT=0.0
# ── TAX SETTINGS (India) ─────────────────────────────────────────
TAX_RATE=0.30
TDS_RATE=0.01
# ── SELF-HEALING ─────────────────────────────────────────────────
ENABLE_SELF_HEALING=true
MAX_HEAL_ATTEMPTS=3
# ── SYSTEM ───────────────────────────────────────────────────────
TRADING_PAIR=BTCUSDT
PORT=8080
# ── V9 CHANGES ───────────────────────────────────────────────────
# Daily trade cap: REMOVED — system trades unlimited while profitable
# Consecutive losses to trigger paper mode: raised 3 → 5
# ── V14 CHANGES (this audit) ──────────────────────────────────────
# TP1/TP2 split corrected to 15%/0% (was silently 40%/35%)
# MIN_WIN_PROBABILITY corrected to 62% base (was silently 68%)
# MAX_CONSECUTIVE_LOSSES raised to 6 (was 5) — graduated threshold
#   now escalates required confidence at 2/3/4/5 losses instead
# PAPER_MIN_TRADES lowered to 1 (was 2) — recovery is profit-based,
#   not time-gated
